# Copy this file to ".env" and fill in your real values for local testing.
#   cp .env.example .env
#
# The .env file is git-ignored so your secrets never get committed.
# In GitHub Actions these same names are provided as repository Secrets instead
# (Settings -> Secrets and variables -> Actions).

# --- Adzuna API credentials ---
# Register a free account at https://developer.adzuna.com/ to get these.
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# --- Telegram bot credentials ---
# Create a bot by messaging @BotFather on Telegram (/newbot) to get the token.
# Get your chat id by messaging your new bot, then visiting:
#   https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# and reading the "chat":{"id": ...} value. See the README for full steps.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
